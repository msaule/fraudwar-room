FRAUDWAR_DATA_DIR=data/generated
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000

# Optional. Core demo works without API keys or heavyweight ML dependencies.
FRAUDWAR_ENABLE_CASE_SUMMARIES=0
FRAUDWAR_CASE_SUMMARY_PROVIDER=local
FRAUDWAR_CASE_SUMMARY_MODEL=gpt-4.1-mini
